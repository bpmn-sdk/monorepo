{
	"name": "@bpmnkit/worker-client",
	"version": "0.0.1",
	"description": "Thin Zeebe REST client for standalone BPMNKit workers — works with reebe and Camunda 8",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": ["LICENSE", "README.md", "dist/**/*.js", "dist/**/*.d.ts"],
	"scripts": {
		"build": "tsc",
		"typecheck": "tsc --noEmit",
		"check": "biome check ."
	},
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/bpmnkit/monorepo"
	},
	"license": "MIT",
	"homepage": "https://bpmnkit.com",
	"bugs": {
		"url": "https://github.com/bpmnkit/monorepo/issues"
	}
}
