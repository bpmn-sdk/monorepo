---
import "../styles/global.css"
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>404 — Page not found · BPMN Kit</title>
  <meta name="description" content="This page doesn't exist — but your processes can still run." />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <style>
    .nf-wrap {
      min-height: 100dvh;
      display: flex;
      flex-direction: column;
    }

    .nf-body {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: calc(var(--nav-h) + 64px) 24px 80px;
    }

    .nf-inner {
      text-align: center;
      max-width: 560px;
    }

    .nf-code {
      font-size: clamp(7rem, 22vw, 11rem);
      font-weight: 800;
      line-height: 1;
      letter-spacing: -0.05em;
      margin-bottom: 32px;
      background: linear-gradient(
        90deg,
        var(--accent-bright) 0%,
        var(--teal) 33%,
        var(--pink) 66%,
        var(--accent-bright) 100%
      );
      background-size: 200% auto;
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      animation: shimmer 4s linear infinite;
    }

    /* Mini BPMN flow diagram — decorative */
    .nf-flow {
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 36px;
      opacity: 0.65;
    }

    .nf-h1 {
      font-size: clamp(1.4rem, 3vw, 2rem);
      font-weight: 700;
      color: var(--text);
      margin-bottom: 14px;
      letter-spacing: -0.02em;
    }

    .nf-p {
      font-size: 15px;
      color: var(--text-muted);
      line-height: 1.75;
      margin-bottom: 40px;
    }

    .nf-actions {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 12px;
      flex-wrap: wrap;
    }

    .btn-ghost {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 22px;
      font-size: 14px;
      font-weight: 500;
      color: var(--text-muted);
      border: 1px solid var(--border);
      border-radius: 10px;
      transition: color 0.2s, border-color 0.2s, background 0.2s;
      text-decoration: none;
    }

    .btn-ghost:hover {
      color: var(--text);
      border-color: oklch(30% 0.04 270);
      background: oklch(12% 0.025 270 / 0.6);
      text-decoration: none;
    }
  </style>
</head>
<body>

  <!-- Fixed page backgrounds -->
  <div class="aurora" aria-hidden="true">
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>
  </div>
  <div class="dots" aria-hidden="true"></div>
  <div class="grain" aria-hidden="true"></div>

  <!-- Nav -->
  <nav class="nav" aria-label="Main navigation">
    <div class="nav-inner">
      <a href="/" class="nav-logo" aria-label="BPMN Kit home">
