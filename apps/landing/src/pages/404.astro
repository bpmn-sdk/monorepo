  <div class="nf-wrap">
    <div class="nf-body">
      <div class="nf-inner">

        <div class="nf-code" aria-label="404">404</div>

        <!-- Decorative BPMN process flow -->
        <div class="nf-flow" aria-hidden="true">
          <svg width="280" height="56" viewBox="0 0 280 56" fill="none" xmlns="http://www.w3.org/2000/svg">
            <!-- Start event -->
            <circle cx="22" cy="28" r="16" stroke="oklch(72% 0.18 185)" stroke-width="1.5"/>
            <!-- Arrow: start → task -->
            <line x1="38" y1="28" x2="58" y2="28" stroke="oklch(45% 0.04 270)" stroke-width="1.5"/>
            <path d="M55 23.5 L62 28 L55 32.5" stroke="oklch(45% 0.04 270)" stroke-width="1.5" stroke-linejoin="round"/>
            <!-- Task box -->
            <rect x="62" y="10" width="98" height="36" rx="6" stroke="oklch(55% 0.12 280)" stroke-width="1.5"/>
            <text x="111" y="32" text-anchor="middle" font-size="11" fill="oklch(58% 0.03 270)" font-family="-apple-system, BlinkMacSystemFont, sans-serif">GET /this-page</text>
            <!-- Arrow: task → end -->
            <line x1="160" y1="28" x2="182" y2="28" stroke="oklch(45% 0.04 270)" stroke-width="1.5"/>
            <path d="M179 23.5 L186 28 L179 32.5" stroke="oklch(45% 0.04 270)" stroke-width="1.5" stroke-linejoin="round"/>
            <!-- Error end event (thick border = end event, lightning bolt = error) -->
            <circle cx="202" cy="28" r="16" stroke="oklch(65% 0.22 20)" stroke-width="3"/>
            <circle cx="202" cy="28" r="12" stroke="oklch(65% 0.22 20)" stroke-width="1" stroke-dasharray="2 2" opacity="0.4"/>
            <!-- Lightning bolt (error marker) -->
            <path d="M205 18 L199 27 L204 27 L199 38 L207 25 L202 25 Z" fill="oklch(65% 0.22 20)" opacity="0.9"/>
          </svg>
        </div>

        <h1 class="nf-h1">Page not found</h1>
        <p class="nf-p">
          This sequence flow reached a dead end.<br>
          The page you're looking for doesn't exist or was moved.
        </p>

        <div class="nf-actions">
          <a href="/" class="btn-primary">
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <path d="M1 8.5L8 2l7 6.5" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M3 7v7h4v-4h2v4h4V7" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Back to home
          </a>
          <a href="/editor" class="btn-ghost">
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <rect x="1.5" y="1.5" width="13" height="13" rx="2"/>
              <path d="M5 8h6M8 5v6" stroke-linecap="round"/>
            </svg>
            Open editor
          </a>
        </div>

      </div>
    </div>
  </div>

  <!-- Footer -->
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-left">
