{
	"name": "@bpmn-sdk/ai-server",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"dependencies": {
		"@bpmn-sdk/core": "workspace:*"
	},
	"scripts": {
		"start": "node dist/index.js",
		"build": "tsc",
		"typecheck": "tsc --noEmit",
		"check": "biome check .",
		"dev": "node --watch dist/index.js",
		"bundle": "esbuild src/index.ts --bundle --platform=node --format=cjs --outfile=dist/bundle.cjs && esbuild src/mcp-server.ts --bundle --platform=node --format=cjs --outfile=dist/mcp-server.cjs"
	}
}
