{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"jsx": "react-jsx",
		"jsxImportSource": "preact",
		"declaration": false,
		"declarationMap": false,
		"sourceMap": false,
		"noEmit": true,
		"outDir": "dist",
		"rootDir": "src",
		"verbatimModuleSyntax": false
	},
	"include": ["src"]
}
