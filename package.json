{
	"name": "@bpmnkit/monorepo",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@10.21.0",
	"scripts": {
		"build": "node scripts/sync-license.mjs && node scripts/generate-readmes.mjs && node scripts/check-packages.mjs && pnpm turbo build",
		"typecheck": "pnpm turbo typecheck",
		"lint": "biome check .",
		"format": "biome check --write .",
		"test": "pnpm turbo test",
		"check": "pnpm turbo check",
		"verify": "pnpm turbo build typecheck check test",
		"changeset": "changeset",
		"version-packages": "changeset version && pnpm format",
		"release": "pnpm turbo build && changeset publish",
		"fix-bpmn": "node scripts/fix-bpmn.mjs",
		"update-connectors": "node scripts/update-connectors.mjs",
		"docs:dev": "pnpm --filter @bpmnkit/docs dev",
		"docs:build": "pnpm turbo build --filter @bpmnkit/docs",
		"proxy": "pnpm --filter @bpmnkit/proxy start",
		"proxy-rs": "cargo build --manifest-path apps/proxy-rs/Cargo.toml && apps/proxy-rs/target/debug/ai-server",
		"proxy-rs:build": "cargo build --manifest-path apps/proxy-rs/Cargo.toml --release",
		"desktop:dev": "pnpm --filter @bpmnkit/desktop tauri:dev",
		"desktop:build": "pnpm --filter @bpmnkit/desktop tauri:build",
		"build:wasm": "wasm-pack build apps/reebe/crates/reebe-wasm --target web --out-dir \"$(pwd)/apps/reebe-wasm\""
	},
	"devDependencies": {
		"@astrojs/check": "^0.9",
		"@biomejs/biome": "^1.9.4",
		"@changesets/changelog-github": "^0.5.2",
		"@changesets/cli": "^2.29.8",
		"@preact/preset-vite": "^2.9.0",
		"@resvg/resvg-js": "^2.6.2",
		"@tailwindcss/vite": "^4.0.0",
		"@tauri-apps/cli": "^2",
		"@types/better-sqlite3": "^7.6.13",
		"@types/node": "^22.0.0",
		"astro": "^6",
		"esbuild": "^0.25.0",
		"happy-dom": "^20.7.0",
		"tailwindcss": "^4.0.0",
		"turbo": "^2.4.4",
		"typescript": "^5.7.3",
		"vite": "^8.0.3",
		"vitest": "^3.0.5",
		"wrangler": "^4",
		"yaml": "^2.8.2"
	}
}
